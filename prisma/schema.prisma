generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id       String   @id @default(cuid())
  name     String
  email    String   @unique
  password String
  role     Role     @default(SELLER)
  tickets  Ticket[] // Las ventas asociadas a este vendedor
}

enum Role {
  ADMIN
  SELLER
}

model Ticket {
  id          String    @id @default(cuid())
  number      Int       @unique // El número de la rifa (único)
  status      Status    @default(AVAILABLE)
  
  // Datos del Comprador (se llenan al vender)
  buyerName   String?
  buyerPhone  String?
  soldAt      DateTime?

  // Relación con el Vendedor (quién lo vendió)
  seller      User?     @relation(fields: [userId], references: [id])
  userId      String?
}

enum Status {
  AVAILABLE
  RESERVED
  SOLD
}
