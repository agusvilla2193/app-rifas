generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(SELLER)
  tickets   Ticket[] // Relación: Un vendedor tiene muchos números vendidos
}

enum Role {
  ADMIN
  SELLER
}

model Ticket {
  id            String   @id @default(cuid())
  number        Int      
  status        Status   @default(AVAILABLE)
  buyerName     String?
  buyerPhone    String?
  seller        User?    @relation(fields: [userId], references: [id])
  userId        String?
}

enum Status {
  AVAILABLE
  RESERVED
  SOLD
}
